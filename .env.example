# ==================== FRONTEND (Vite) ====================
# NOTE: Variables prefixed with VITE_ are exposed in the browser. Do not put secrets here.

# Backend API base URL (must include /api/v1)
VITE_API_URL=http://localhost:3001/api/v1

# WebSocket base URL
VITE_WS_URL=ws://localhost:3001/ws

# ==================== SUPABASE ====================
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# Optional (some deployments/scripts may reference this)
VITE_SUPABASE_PROJECT_ID=your-project-id

# ==================== GENAI (Google GenAI SDK) ====================
# Use a restricted browser-safe key only.
VITE_GEMINI_API_KEY=
# Alternative key name used by some modules
VITE_API_KEY=
